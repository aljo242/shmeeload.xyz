{
	# Caddy uses its own internal CA here (no public ACME / no domain needed),
	# so it must NOT try to bind port 80 for HTTP->HTTPS redirects: Pi-hole
	# owns :80 on this box. This keeps Caddy on :443 only.
	auto_https disable_redirects
}

# Served with a cert from Caddy's internal CA. Install that root once per device
# (see deploy/README) to get a valid green-lock over the LAN with no domain.
# Reached at https://shmee.lan via a Pi-hole local DNS record (shmee.lan -> Pi).
# A hostname (not a bare IP) is required so browsers send SNI for cert matching.
https://shmee.lan {
	tls internal
	reverse_proxy shmeeload:8080
}
